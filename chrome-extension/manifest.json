{
  "manifest_version": 3,
  "name": "Hermes Chrome Connector",
  "version": "0.15.38",
  "description": "Companion extension for Hermes Agent that enables local browser automation through 127.0.0.1.",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "alarms",
    "webNavigation",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:16319/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Hermes Chrome Connector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
